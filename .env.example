DISCORD_TOKEN=cola_o_teu_token_aqui

# Optional — paste your Discord server ID for instant /command updates after deploy
# (right-click server icon → Copy Server ID; enables Developer Mode in Discord settings)
DISCORD_GUILD_ID=0

# MongoDB Atlas — shared by bot + Activity APIs on Render
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=sudoku

# Discord Activity (same Render service) — also set on Render dashboard
# VITE_DISCORD_CLIENT_ID must be present at Docker build time (= Application ID)
# DISCORD_CLIENT_SECRET = OAuth2 → Client Secret (NOT the bot token)
VITE_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match Developer Portal → OAuth2 → Redirects
DISCORD_OAUTH_REDIRECT_URI=https://127.0.0.1

# Channel where /play watch announcements are posted (one message per game)
ACTIVITY_WATCH_CHANNEL_ID=1527293243434209300
