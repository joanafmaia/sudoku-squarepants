# Discord Activity (Embedded App) — OAuth credentials
# Application → OAuth2 in https://discord.com/developers/applications
VITE_DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID_HERE
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET_HERE

# Shared with the Fly.io bot — set these on Netlify Functions too
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=sudoku

# Optional: override Activity API server port (default 3001) — só para dev local
# PORT=3001

# Netlify Site settings → Environment variables
#   VITE_DISCORD_CLIENT_ID  (Build + runtime)
#   DISCORD_CLIENT_SECRET   (Functions only)
#   MONGODB_URI             (Functions only)
#   MONGODB_DB              (Functions only)
